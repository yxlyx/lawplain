# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Optional comma-separated extra origins for local/preview deployments.
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://127.0.0.1:3002,http://localhost:3002

# Cloudflare D1 is exposed through the AUTH_DB binding in wrangler.jsonc.
# Create it with: bun run d1:create
